rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Everyone with the link can VIEW the data — no login required.
    // Only signed-in users (the 2 collectors) can ADD, EDIT or DELETE anything.
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
